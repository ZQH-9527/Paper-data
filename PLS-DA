def load_raman_data(file_path):
    df = pd.read_csv(file_path)
    labels = df.iloc[1:, 0].values
    raw_spectra = df.iloc[1:, 1:-1].astype(float).values
    return raw_spectra, labels

MODEL_DIR = "optimized_plsda_results_95target_v2/plsda_model"
PIPELINE_PATH = os.path.join(MODEL_DIR, "tighter_plsda_pipeline.pkl")
ENCODER_PATH = os.path.join(MODEL_DIR, "label_encoder.pkl")
TEST_CSV = "Test.csv"

OUTPUT_DIR = os.path.join(MODEL_DIR, "new_data_evaluation_plsda")
os.makedirs(OUTPUT_DIR, exist_ok=True)

OUTPUT_PREDICTIONS = os.path.join(OUTPUT_DIR, "new_data_predictions.csv")
OUTPUT_REPORT = os.path.join(OUTPUT_DIR, "new_data_classification_report.txt")
OUTPUT_CONFUSION = os.path.join(OUTPUT_DIR, "new_data_confusion_matrix.png")
OUTPUT_SUMMARY = os.path.join(OUTPUT_DIR, "new_data_summary.csv")

def main():
    print("Loading model and label encoder...")
    pipeline = joblib.load(PIPELINE_PATH)
    label_encoder = joblib.load(ENCODER_PATH)
    print("Model loaded.")

    print(f"Loading test data from {TEST_CSV}...")
    X_test_raw, y_test_raw = load_raman_data(TEST_CSV)
    print(f"Test samples: {X_test_raw.shape[0]}, features: {X_test_raw.shape[1]}")

    y_pred_encoded = pipeline.predict(X_test_raw)
    y_pred_proba = pipeline.predict_proba(X_test_raw)
    y_pred_labels = label_encoder.inverse_transform(y_pred_encoded)

    has_labels = not np.all(np.char.strip(y_test_raw.astype(str)) == '')
    if has_labels:
        try:
            y_true_encoded = label_encoder.transform(y_test_raw)
        except ValueError as e:
            print(f"Warning: unknown labels encountered -> {e}")
            print("Metrics will be skipped.")
            has_labels = False

    pred_df = pd.DataFrame({
        'True_Label': y_test_raw if has_labels else 'N/A',
        'Predicted_Label': y_pred_labels
    })
    for i, class_name in enumerate(label_encoder.classes_):
        pred_df[f'Prob_{class_name}'] = y_pred_proba[:, i]
    pred_df.to_csv(OUTPUT_PREDICTIONS, index=False, encoding='utf-8-sig')
    print(f"Predictions saved to {OUTPUT_PREDICTIONS}")

    if has_labels:
        acc = accuracy_score(y_true_encoded, y_pred_encoded)
        precision = precision_score(y_true_encoded, y_pred_encoded, average='macro', zero_division=0)
        recall = recall_score(y_true_encoded, y_pred_encoded, average='macro', zero_division=0)
        f1 = f1_score(y_true_encoded, y_pred_encoded, average='macro', zero_division=0)

        print("\nClassification Report:")
        report = classification_report(y_true_encoded, y_pred_encoded,
                                       target_names=label_encoder.classes_, zero_division=0)
        print(report)
        print(f"Accuracy: {acc:.4f}")
        print(f"Macro Precision: {precision:.4f}")
        print(f"Macro Recall: {recall:.4f}")
        print(f"Macro F1: {f1:.4f}")

        with open(OUTPUT_REPORT, 'w', encoding='utf-8') as f:
            f.write(report)
            f.write(f"\nAccuracy: {acc:.4f}\n")
            f.write(f"Macro Precision: {precision:.4f}\n")
            f.write(f"Macro Recall: {recall:.4f}\n")
            f.write(f"Macro F1: {f1:.4f}\n")
        print(f"Report saved to {OUTPUT_REPORT}")

        summary = pd.DataFrame({
            'Metric': ['Accuracy', 'Macro Precision', 'Macro Recall', 'Macro F1'],
            'Value': [acc, precision, recall, f1]
        })
        summary.to_csv(OUTPUT_SUMMARY, index=False, encoding='utf-8-sig')
        print(f"Summary saved to {OUTPUT_SUMMARY}")

        cm = confusion_matrix(y_true_encoded, y_pred_encoded)
        fig, ax = plt.subplots(figsize=(6.0, 5.5), dpi=900)
        sns.heatmap(cm, annot=True, fmt='d', cmap='Greens',
                    xticklabels=label_encoder.classes_,
                    yticklabels=label_encoder.classes_,
                    annot_kws={'size': 12}, ax=ax)
        ax.set_title('PLS-DA Confusion Matrix on New Data', fontweight='bold')
        ax.set_xlabel('Predicted Label', fontweight='bold')
        ax.set_ylabel('True Label', fontweight='bold')
        plt.setp(ax.get_xticklabels(), rotation=45, ha='right', rotation_mode='anchor')
        plt.setp(ax.get_yticklabels(), rotation=0)
        plt.tight_layout()
        plt.savefig(OUTPUT_CONFUSION, dpi=900, bbox_inches='tight')
        plt.close()
        print(f"Confusion matrix saved to {OUTPUT_CONFUSION}")

    print("\nFirst 5 predictions:")
    print(pred_df.head())

if __name__ == "__main__":
    main()
