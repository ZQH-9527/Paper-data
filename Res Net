    with open(params_path, "r") as f:
        for line in f:
            if '=' in line:
                key, value = line.strip().split('=')
                if key == 'smooth_method':
                    smooth_method = value
                elif key == 'smooth_window':
                    smooth_window = int(value)
                elif key == 'smooth_polyorder':
                    smooth_polyorder = int(value)
                elif key == 'snv_applied':
                    snv_applied = (value.lower() == 'true')
